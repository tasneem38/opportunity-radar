{
  "version": 2,
  "builds": [
    {
      "src": "vercel_api/index.py",
      "use": "@vercel/python",
      "config": { "runtime": "python3.11" }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/vercel_api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ],
  "crons": [
    {
      "path": "/api/jobs/filing",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/jobs/daily_events",
      "schedule": "0 1 * * *"
    }
  ]
}